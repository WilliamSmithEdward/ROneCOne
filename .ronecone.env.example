# Reserved ROneCOne local diagnostics schema.
# Copy this file to %USERPROFILE%\.ronecone.env for local use.
# Never commit the user-space file.
# Version 0.3.0 does not read this file or emit runtime logs.

# Logging is disabled unless this value is exactly true.
RONECONE_LOG_ENABLED=false

# Defaults to %LOCALAPPDATA%\ROneCOne\logs when omitted.
RONECONE_LOG_DIRECTORY=

# Supported levels: error, warning, information, debug, trace.
RONECONE_LOG_LEVEL=information

# Retain at most this many log files. Logging remains local.
RONECONE_LOG_RETAIN_FILES=10
